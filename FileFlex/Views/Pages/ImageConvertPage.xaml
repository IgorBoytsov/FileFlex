<Page x:Class="FileFlex.Views.Pages.ImageConvertPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local1="clr-namespace:FileFlex.ViewModels"
      xmlns:fa="http://schemas.fontawesome.com/icons/"
      mc:Ignorable="d" 
      d:DesignHeight="730" d:DesignWidth="1300"
      FontFamily="Bahnschrift SemiBold SemiCondensed"
      FontSize="15"
      Title="ImageConvertPage">

    <Grid Background="#FF282C34">
        <Grid.RowDefinitions>
            <RowDefinition Height="1"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="150"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="1"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1"/>
            <ColumnDefinition Width="350" MinWidth="350"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="300" MinWidth="100"/>
            <ColumnDefinition Width="1"/>
        </Grid.ColumnDefinitions>

        <!--#region GridSpliter -->

        <!-- Разделение грида со списком файлов -->
        <GridSplitter Background="Black"
              Grid.Column="3"
              Grid.RowSpan="5"  
              HorizontalAlignment="Center"
              Width="4"
              Cursor="SizeWE"
              ShowsPreview="False"/>
        <!--#endregion-->

        <!--#region Элементы управление-->

        <WrapPanel Grid.Row="1" Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Button Content="Предпросмотр" Command="{Binding PreviewRenderImageCommand}" Template="{StaticResource ControlButton}" Margin="0,0,10,0"/>
            <Button Content="Конверт. и сохр." Template="{StaticResource ControlButton}" Margin="0,0,10,0"/>
            <Button Content="Сохранить" Command="{Binding SaveCurrentFileCommand}" Template="{StaticResource ControlButton}" Margin="0,0,10,0"/>
            <Button Content="Сбросить" Command="{Binding ClearOutputImageCommand}" Template="{StaticResource ControlButton}" Margin="0,0,10,0"/>
        </WrapPanel>

        <!--#endregion-->

        <!--#region Область добавления файлов-->
        <DockPanel Grid.Row="1" Grid.RowSpan="2" Grid.Column="1">
            <Border BorderBrush="Blue" Background="White" BorderThickness="4" CornerRadius="30" DockPanel.Dock="Bottom">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Label Content="Перетащите файл" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="15"/>
                    <Button Content="Выбрать файл" Command="{Binding SelectFileCommand}" Template="{StaticResource ControlButton}" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </DockPanel>
        <!--#endregion-->

        <!--#region Область с списком настроек-->
        <ScrollViewer Grid.Row="3" Grid.Column="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.ColumnSpan="2" Grid.Row="0" Background="#595958" >
                    <DockPanel>
                        <fa:ImageAwesome Icon="Solid_Wrench" Width="25"/>
                        <Label Content="Настройки формата" Style="{StaticResource SettingLabelStyle}"/>
                    </DockPanel>
                </Border>

                <DockPanel Grid.Column="0" Grid.Row="1" >
                    <Label Content="Целевой формат" Style="{StaticResource SettingLabelStyle}"/>
                    <fa:ImageAwesome Icon="Solid_QuestionCircle" Foreground="LightBlue" Height="15" Width="15"  HorizontalAlignment="Left">
                        <fa:ImageAwesome.ToolTip>
                            <TextBlock TextWrapping="WrapWithOverflow" Background="White" FontSize="20" Text="{Binding ToolTipTargetFormatLabelText}" />
                        </fa:ImageAwesome.ToolTip>
                    </fa:ImageAwesome>
                </DockPanel>

                <ComboBox Grid.Column="1" Grid.Row="1" ItemsSource="{Binding ConvertFormat}" SelectedItem="{Binding SelectedFormat}" Width="110" Height="25"/>

                <Border Grid.ColumnSpan="2" Grid.Row="2" Background="#595958">
                    <DockPanel>
                        <fa:ImageAwesome Icon="Solid_Wrench" Width="25"/>
                        <Label Content="Настройки качества" Style="{StaticResource SettingLabelStyle}"/>
                    </DockPanel>
                </Border>

                <Slider Grid.ColumnSpan="2" Grid.Row="4" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,10,0" />
 
                <DockPanel Grid.Column="0" Grid.Row="3">
                    <Label Content="Качество" Style="{StaticResource SettingLabelStyle}"/>
                    <fa:ImageAwesome Icon="Solid_QuestionCircle" Foreground="LightBlue" Height="15" Width="15"  HorizontalAlignment="Left">
                        <fa:ImageAwesome.ToolTip>
                            <TextBlock TextWrapping="WrapWithOverflow" Height="100" Width="500" Background="White" FontSize="20" Text="{Binding ToolTipQualityLabelText}" />
                        </fa:ImageAwesome.ToolTip>
                    </fa:ImageAwesome>
                </DockPanel>

                <Label Grid.Column="0" Grid.Row="5" Content="Значение в % :" Style="{StaticResource SettingLabelStyle}"/>
                <TextBox Grid.Column="1" Grid.Row="5" Text="100" Template="{StaticResource SettingTextBoxTemplate}" Style="{StaticResource SettingTextBoxStyle}"/>

                <Border  Grid.ColumnSpan="2" Grid.Row="7" Background="#595958" >
                    <DockPanel>
                        <fa:FontAwesome Icon="Solid_CropAlt" Height="15" Width="15"/>
                        <Label Content="Изменить размер" Style="{StaticResource SettingLabelStyle}"/>
                        <fa:ImageAwesome Icon="Solid_QuestionCircle" Foreground="LightBlue" Height="15" Width="15"  HorizontalAlignment="Left">
                            <fa:ImageAwesome.ToolTip>
                                <TextBlock TextWrapping="WrapWithOverflow" Height="100" Width="500" Background="White" FontSize="20" Text="{Binding ToolTipResizeLabelText}" />
                            </fa:ImageAwesome.ToolTip>
                        </fa:ImageAwesome>
                    </DockPanel>
                </Border>

                <Label Grid.Column="0" Grid.Row="9" Content="Ширина" HorizontalAlignment="Center" Style="{StaticResource SettingLabelStyle}"/>
                <TextBox Grid.Column="1" Grid.Row="9" Width="100" Template="{StaticResource SettingTextBoxTemplate}" Style="{StaticResource SettingTextBoxStyle}"/>

                <Label Grid.Column="0" Grid.Row="11" Content="Высота" HorizontalAlignment="Center" Style="{StaticResource SettingLabelStyle}"/>
                <TextBox Grid.Column="1" Grid.Row="11" Width="100" Template="{StaticResource SettingTextBoxTemplate}" Style="{StaticResource SettingTextBoxStyle}"/>

                <Border Grid.ColumnSpan="2" Grid.Row="13" Background="#595958">
                    <DockPanel>
                        <fa:ImageAwesome Icon="Solid_Palette" Height="15" Width="15"/>
                        <Label  Content="Цветовой фильтр" Style="{StaticResource SettingLabelStyle}"/>
                        <fa:ImageAwesome Icon="Solid_QuestionCircle" Foreground="LightBlue" Height="15" Width="15"  HorizontalAlignment="Left">
                            <fa:ImageAwesome.ToolTip>
                                <TextBlock TextWrapping="WrapWithOverflow" Background="White" FontSize="20" Text="{Binding ToolTipCallorFilterLabelText}" />
                            </fa:ImageAwesome.ToolTip>
                        </fa:ImageAwesome>
                    </DockPanel>
                </Border>

                <ComboBox Style="{StaticResource DarkComboBoxColorStyle}" Grid.ColumnSpan="2" Grid.Row="14" ItemsSource="{Binding ColorFilter}" SelectedItem="{Binding SelectedColorFilter}" VerticalAlignment="Center" Width="200" Height="20" Margin="0,5,0,5"/>

                <Border Grid.ColumnSpan="2" Grid.Row="15" Background="#595958">
                    <DockPanel>
                        <fa:ImageAwesome Icon="Solid_Hammer" Height="15" Width="15"/>
                        <Label Content="Дополнительные настройки" Style="{StaticResource SettingLabelStyle}"/>
                        <fa:ImageAwesome Icon="Solid_QuestionCircle" Foreground="LightBlue" Height="15" Width="15"  HorizontalAlignment="Left">
                            <fa:ImageAwesome.ToolTip>
                                <TextBlock TextWrapping="WrapWithOverflow" Background="White" FontSize="20" Text="{Binding ToolTipAdditionalSettingsLabelText}" />
                            </fa:ImageAwesome.ToolTip>
                        </fa:ImageAwesome>
                    </DockPanel>
                </Border>

                <StackPanel Grid.Column="0" Grid.Row="16" >
                    <CheckBox Content="Добавить файлы в архив" Style="{StaticResource SettingCheckBoxStyle}"/>
                </StackPanel>

            </Grid>
        </ScrollViewer>
        <!--#endregion-->

        <!--#region Отображение информации о файле-->
        <ScrollViewer Grid.Column="2" Grid.Row="2" Grid.RowSpan="3" >
            <Grid Background="#FF282C34">

                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <GroupBox MaxHeight="700" Header="Исходное изображение" Grid.Row="0" Grid.Column="0" BorderBrush="Black" Foreground="White" BorderThickness="2" FontSize="20" Margin="10" FontFamily="Bahnschrift SemiBold SemiCondensed" >
                    <Image Source="{Binding ImageSource}" HorizontalAlignment="Center" Margin="15" />
                </GroupBox>

                <StackPanel Grid.Column="0" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Top">
                    <GroupBox MaxHeight="500" Header="Информация"  BorderBrush="Black" Foreground="White" BorderThickness="2" FontSize="30" Margin="10" FontFamily="Bahnschrift SemiBold SemiCondensed">
                        <Grid>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Label Content="Имя файла" Grid.Row="0" Grid.Column="0" Style="{StaticResource InfoLabelStyle}" Margin="10"/>
                            <TextBox Text="{Binding ImageSource}" Grid.Row="0" Grid.Column="1" Style="{StaticResource SettingTextBoxStyle}" Template="{StaticResource SettingTextBoxTemplate}" Margin="10"/>

                            <Label Content="Тип файла" Grid.Row="1" Grid.Column="0" Style="{StaticResource InfoLabelStyle}" Margin="10"/>
                            <TextBox Text="{Binding InputFileTypeSelected}" Grid.Row="1" Grid.Column="1" Style="{StaticResource SettingTextBoxStyle}" Template="{StaticResource SettingTextBoxTemplate}" Margin="10"/>

                            <Label Content="Размер файла" Grid.Row="2" Grid.Column="0" Style="{StaticResource InfoLabelStyle}" Margin="10"/>
                            <TextBox Text="{Binding InputFileSizeSelected}" Grid.Row="2" Grid.Column="1" Style="{StaticResource SettingTextBoxStyle}" Template="{StaticResource SettingTextBoxTemplate}" Margin="10"/>

                            <Label Content="Разрешение файл" Grid.Row="3" Grid.Column="0" Style="{StaticResource InfoLabelStyle}" Margin="10"/>
                            <TextBox Text="{Binding InputFileResolutionSelected}" Grid.Row="3" Grid.Column="1" Style="{StaticResource SettingTextBoxStyle}" Template="{StaticResource SettingTextBoxTemplate}" Margin="10"/>

                        </Grid>
                    </GroupBox>
                </StackPanel>

                <GroupBox MaxHeight="700" Header="Выходное изображение" Grid.Row="0" Grid.Column="1" BorderBrush="Black" Foreground="White" BorderThickness="2" FontSize="20" Margin="10" FontFamily="Bahnschrift SemiBold SemiCondensed" >
                    <Image Source="{Binding OutputImageSource}" HorizontalAlignment="Center" Margin="15" />
                </GroupBox>

                <StackPanel Grid.Column="1" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Top">
                    <GroupBox MaxHeight="500" Header="Информация"  BorderBrush="Black" Foreground="White" BorderThickness="2" FontSize="30" Margin="10" FontFamily="Bahnschrift SemiBold SemiCondensed">
                        <Grid>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Label Content="Имя файла" Grid.Row="0" Grid.Column="0" Style="{StaticResource InfoLabelStyle}" Margin="10"/>
                            <TextBox Text="{Binding OutputFileNameSelected}" Grid.Row="0" Grid.Column="1" Style="{StaticResource SettingTextBoxStyle}" Template="{StaticResource SettingTextBoxTemplate}" Margin="10"/>

                            <Label Content="Тип файла" Grid.Row="1" Grid.Column="0" Style="{StaticResource InfoLabelStyle}" Margin="10"/>
                            <TextBox Text="{Binding OutputFileTypeSelected}" Grid.Row="1" Grid.Column="1" Style="{StaticResource SettingTextBoxStyle}" Template="{StaticResource SettingTextBoxTemplate}" Margin="10"/>

                            <Label Content="Размер файла" Grid.Row="2" Grid.Column="0" Style="{StaticResource InfoLabelStyle}" Margin="10"/>
                            <TextBox Text="{Binding OutputFileSizeSelected}" Grid.Row="2" Grid.Column="1" Style="{StaticResource SettingTextBoxStyle}" Template="{StaticResource SettingTextBoxTemplate}" Margin="10"/>

                            <Label Content="Разрешение файл" Grid.Row="3" Grid.Column="0" Style="{StaticResource InfoLabelStyle}" Margin="10"/>
                            <TextBox Text="{Binding OutputFileResolutionSelected}" Grid.Row="3" Grid.Column="1" Style="{StaticResource SettingTextBoxStyle}" Template="{StaticResource SettingTextBoxTemplate}" Margin="10"/>

                        </Grid>
                    </GroupBox>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!--#region -->

        <!--#region Список файлов/Управление списком файлов-->
        <StackPanel Grid.Row="1" Grid.Column="4" Orientation="Horizontal">
            <ComboBox ItemsSource="{Binding SortingSelection}" SelectedItem="{Binding SelectedFileFilter}" Width="150" Height="25"/>
            <Button Content="Удалить все файлы" Command="{Binding DeleteFileCommand}" Template="{StaticResource ControlButton}" Margin="10,0,0,0"/>
        </StackPanel>

        <Grid Grid.Row="2" Grid.RowSpan="3" Grid.Column="4" Margin="0,0,5,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <ListView ItemsSource="{Binding ListFiles}" SelectedItem="{Binding SelectedFileInformation}" Grid.RowSpan="2" Margin="0,0,10,0">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Имя" Width="180" DisplayMemberBinding="{Binding FileName}"/>
                        <GridViewColumn Header="Размер" Width="100"  DisplayMemberBinding="{Binding FileSize}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>
        

        <!--#endregion-->
    </Grid>

</Page>
