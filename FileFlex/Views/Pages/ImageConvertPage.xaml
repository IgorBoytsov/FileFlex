                            <Label Content="Тип файла" Grid.Row="1" Grid.Column="0" Margin="10"/>
                            <TextBox Text=".png" Grid.Row="1" Grid.Column="1" Margin="10"/>

                            <Label Content="Размер файла" Grid.Row="2" Grid.Column="0" Margin="10"/>
                            <TextBox Text="456кб" Grid.Row="2" Grid.Column="1" Margin="10"/>

                            <Label Content="Разрешение файл" Grid.Row="3" Grid.Column="0" Margin="10"/>
                            <TextBox Text="2560 x 1440" Grid.Row="3" Grid.Column="1" Margin="10"/>

                        </Grid>
                    </GroupBox>
                </StackPanel>
            </Grid>
        </ScrollViewer>

